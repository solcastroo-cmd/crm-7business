{
  "name": "crm-7business",
  "version": "2.0.0",
  "description": "CRM 7Business — Micro-SaaS para lojas de veículos",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "migrate": "tsx scripts/migrate.ts",
    "start": "npm run migrate && next start",
    "postinstall": "node setup-env.js",
    "lint": "next lint",
    "check": "tsx scripts/check.ts",
    "setup:env": "tsx scripts/setup-env.ts",
    "setup:db": "tsx scripts/setup-db.ts",
    "setup:railway": "tsx scripts/setup-railway.ts",
    "fetch:keys": "tsx scripts/fetch-supabase-keys.ts",
    "whatsapp:install": "npm install --no-save @whiskeysockets/baileys qrcode-terminal qrcode pino",
    "whatsapp:connect": "node scripts/whatsapp/connect-local.js",
    "whatsapp:verify": "bash scripts/whatsapp/verify-session.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/pg": "^8.20.0",
    "axios": "^1.14.0",
    "date-fns": "^4.1.0",
    "nanoid": "^3.3.7",
    "next": "^16.2.2",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
